[Unit]
Description=무한매수법 자동매매 대시보드
After=network.target

[Service]
Type=simple
User={USER}
WorkingDirectory={APP_DIR}
EnvironmentFile={APP_DIR}/.env
ExecStart={APP_DIR}/.venv/bin/python -m uvicorn web.app:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
